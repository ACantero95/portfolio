---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/Navbar.astro";
import Hero from "../components/Hero.astro";
import Metrics from "../components/Metrics.astro";
import Experience from "../components/Experience.astro";
import Projects from "../components/Projects.astro";
import Skills from "../components/Skills.astro";
import Contact from "../components/Contact.astro";
import Footer from "../components/Footer.astro";
const profile = {
  name: "Alberto Cantero",
  role: "Senior Web Developer / Frontend Team Lead",
  location: "Cáceres, España - Remoto",
  summary:
    "Lidero equipos frontend y desarrollo productos web escalables. +6 años construyendo soluciones full stack en banca, ciberseguridad e industria — desde arquitectura de componentes hasta decisiones técnicas de producto.",
  email: "hcanteroa@gmail.com",
  linkedin: "https://www.linkedin.com/in/alberto-cantero-a31b65311",
  github: "https://github.com/ACantero95",
  cv: "#",
};

const skills = [
  // Lenguajes
  { name: "JavaScript", icon: "js" },
  { name: "TypeScript", icon: "ts" },
  { name: "Java", icon: "java" },
  { name: "Python", icon: "python" },
  // Frontend
  { name: "React", icon: "react" },
  { name: "Angular", icon: "angular" },
  { name: "Next.js", icon: "next" },
  { name: "Astro", icon: "astro" },
  // Backend
  { name: "Node.js", icon: "node" },
  { name: "Express", icon: "express" },
  { name: "Spring Boot", icon: "spring" },
  { name: "Django", icon: "django" },
  // Cloud & DevOps
  { name: "AWS", icon: "aws" },
  { name: "Azure", icon: "azure" },
  { name: "Docker", icon: "docker" },
  // Datos
  { name: "PostgreSQL", icon: "postgre" },
  { name: "MongoDB", icon: "mongo" },
  // Herramientas
  { name: "Git", icon: "git" },
  { name: "GitHub", icon: "github" },
  { name: "Jira", icon: "jira" },
  { name: "Githhub Copilot", icon: "copilot" },
  { name: "Cursor", icon: "cursor" },
];

const experience = [
  {
    period: "2024 — Actualidad",
    role: "Lead Web Developer / Frontend Team Lead",
    company: "Minery Report",
    detail:
      "Liderazgo técnico del área web, coordinando el equipo frontend y definiendo la arquitectura bajo metodologías ágiles. Toma de decisiones tecnológicas, mentoría del equipo y optimización de flujos de desarrollo.",
  },
  {
    period: "2022 — 2024",
    role: "Desarrollador de Software — IAM (Ciberseguridad)",
    company: "SIA (Indra)",
    detail:
      "Implementación y gestión de soluciones de Identidad y Control de Acceso para el sector bancario (Banco Santander). Automatización de procesos de seguridad y consolidación de sistemas de acceso.",
  },
  {
    period: "2022",
    role: "Desarrollador Full Stack",
    company: "Minery Report",
    detail:
      "Desarrollo de APIs en Node.js, frontales con Angular y React, soporte backend con Python y Django. Trabajo con Docker, Azure, MongoDB y AWS.",
  },
  {
    period: "2021 — 2022",
    role: "Analista / Programador Full Stack",
    company: "NTT DATA Europe & Latam",
    detail:
      "Ciclo de vida completo de desarrollo con Angular, Node.js y Spring Boot. Gestión del equipo de desarrollo y seguimiento técnico con cliente directo.",
  },
  {
    period: "2020 — 2021",
    role: "Desarrollador Node.js · QA Tester",
    company: "VIEWNEXT",
    detail:
      "Integración de Watson Assistant (IBM) en apps y webs con Node.js y Angular. Anteriormente, diseño y ejecución de pruebas manuales y de rendimiento con ALM y VuGen.",
  },
];

const projects = [
  {
    title: "Plataforma Web Minery Report",
    description:
      "Plataforma de reporting con arquitectura frontend escalable, liderada desde cero coordinando equipo y definiendo stack tecnológico.",
    tech: "React · Node.js · Ágil",
    link: "#",
  },
  {
    title: "Sistema IAM Banca",
    description:
      "Solución de gestión de identidad y acceso para Banco Santander: automatización de flujos de seguridad y consolidación de permisos a escala enterprise.",
    tech: "Java · IAM · Ciberseguridad",
    link: "#",
  },
  {
    title: "Integración Watson Assistant",
    description:
      "Integración de chatbot IA de IBM en múltiples plataformas web y aplicaciones móviles, incluyendo entrenamiento de modelos conversacionales.",
    tech: "Node.js · Angular · IBM Cloud",
    link: "#",
  },
];

const metrics = [
  { label: "Años de experiencia", value: "6+" },
  { label: "Empresas", value: "5" },
  { label: "Sectores", value: "4" },
];

const seo = {
  title: `${profile.name} - ${profile.role}`,
  description: `Portfolio profesional de ${profile.name}, especialista en desarrollo frontend y producto digital.`,
};
---

<BaseLayout title={seo.title} description={seo.description}>
  <script
    type="application/ld+json"
    set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      name: profile.name,
      jobTitle: profile.role,
      email: profile.email,
      url: profile.linkedin,
      sameAs: [profile.linkedin, profile.github],
    })}
  />

  <Navbar
    name={profile.name}
    linkedin={profile.linkedin}
    github={profile.github}
    cv={profile.cv}
  />
  <Hero
    role={profile.role}
    summary={profile.summary}
    location={profile.location}
    email={profile.email}
  />
  <Metrics metrics={metrics} />
  <Experience jobs={experience} />
  <Projects projects={projects} />
  <Skills skills={skills} />
  <Contact email={profile.email} />
  <Footer
    name={profile.name}
    linkedin={profile.linkedin}
    github={profile.github}
  />
</BaseLayout>
