---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/Navbar.astro";
import Hero from "../components/Hero.astro";
import Metrics from "../components/Metrics.astro";
import Experience from "../components/Experience.astro";
import Projects from "../components/Projects.astro";
import Skills from "../components/Skills.astro";
import Contact from "../components/Contact.astro";
import Footer from "../components/Footer.astro";

const profile = {
  name: "Alberto Cantero",
  role: "Lead Web Developer / Frontend Team Lead",
  location: "Cáceres, España",
  summary:
    "Creo experiencias digitales rápidas, claras y centradas en negocio. Me enfoco en interfaces de alto impacto y en producto end-to-end.",
  email: "hcanteroa@gmail.com",
  linkedin: "https://www.linkedin.com/in/alberto-cantero-a31b65311",
  github: "https://github.com/ACantero95",
  cv: "#",
};

const skills = [
  "JavaScript / TypeScript",
  "React / Next.js",
  "Astro / SEO técnico",
  "Node.js",
  "UX / UI",
  "APIs REST",
  "Testing",
  "Performance web",
];

const experience = [
  {
    period: "2023 — Actualidad",
    role: "Frontend Developer",
    company: "Empresa Actual",
    detail:
      "Diseño y desarrollo de productos web orientados a conversión. Mejora de rendimiento y accesibilidad en entornos productivos.",
  },
  {
    period: "2021 — 2023",
    role: "Full Stack Developer",
    company: "Empresa Anterior",
    detail:
      "Implementación de funcionalidades end-to-end y colaboración directa con negocio para acelerar entregas.",
  },
];

const projects = [
  {
    title: "Proyecto 01",
    description:
      "Landing optimizada para captación de leads con mejora de conversión y carga por debajo de 2 segundos.",
    tech: "Astro · TypeScript · SEO",
    link: "#",
  },
  {
    title: "Proyecto 02",
    description:
      "Panel interno para operaciones con dashboards claros y automatización de procesos repetitivos.",
    tech: "React · Node.js · API",
    link: "#",
  },
  {
    title: "Proyecto 03",
    description:
      "Rediseño de ecommerce con foco en experiencia móvil y arquitectura de componentes escalable.",
    tech: "Next.js · Design System",
    link: "#",
  },
];

const metrics = [
  { label: "Años de experiencia", value: "4+" },
  { label: "Proyectos entregados", value: "25+" },
  { label: "Sectores", value: "6" },
];

const seo = {
  title: `${profile.name} - ${profile.role}`,
  description: `Portfolio profesional de ${profile.name}, especialista en desarrollo frontend y producto digital.`,
};
---

<BaseLayout title={seo.title} description={seo.description}>
  <script
    type="application/ld+json"
    set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      name: profile.name,
      jobTitle: profile.role,
      email: profile.email,
      url: profile.linkedin,
      sameAs: [profile.linkedin, profile.github],
    })}
  />

  <Navbar
    name={profile.name}
    linkedin={profile.linkedin}
    github={profile.github}
    cv={profile.cv}
  />
  <Hero
    role={profile.role}
    summary={profile.summary}
    location={profile.location}
    email={profile.email}
  />
  <Metrics metrics={metrics} />
  <Experience jobs={experience} />
  <Projects projects={projects} />
  <Skills skills={skills} />
  <Contact email={profile.email} />
  <Footer
    name={profile.name}
    linkedin={profile.linkedin}
    github={profile.github}
  />
</BaseLayout>
