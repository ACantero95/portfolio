---
interface Props {
  name: string;
  linkedin: string;
  github: string;
  cv: string;
}

const { name, linkedin, github, cv } = Astro.props;
---

<nav
  class="fixed top-0 inset-x-0 z-50 backdrop-blur-md bg-paper/80 border-b border-line/50"
>
  <div class="max-w-6xl mx-auto flex items-center justify-between px-6 py-4">
    <a
      href="/"
      class="text-sm font-extrabold tracking-tight text-ink hover:text-accent transition-colors"
    >
      {name}<span class="text-accent">.</span>
    </a>
    <div
      class="flex items-center gap-5 text-xs font-semibold uppercase tracking-widest text-subtle"
    >
      <a
        href="#experience"
        class="hover:text-ink transition-colors hidden sm:block">Experiencia</a
      >
      <a
        href="#projects"
        class="hover:text-ink transition-colors hidden sm:block">Proyectos</a
      >
      <a
        href={linkedin}
        target="_blank"
        rel="noreferrer"
        class="hover:text-ink transition-colors">LI</a
      >
      <a
        href={github}
        target="_blank"
        rel="noreferrer"
        class="hover:text-ink transition-colors">GH</a
      >
      <a
        href={cv}
        class="ml-2 px-4 py-2 rounded-full bg-ink text-paper text-xs font-bold hover:bg-accent transition-colors"
      >
        CV ↓
      </a>

      <button
        id="theme-toggle"
        type="button"
        aria-label="Cambiar modo oscuro"
        aria-pressed="false"
        class="ml-1 relative h-7 w-14 rounded-full border border-line bg-surface p-0.5 transition-colors hover:border-accent/60"
      >
        <span
          class="absolute left-1 top-1/2 -translate-y-1/2 text-[10px] text-subtle"
          aria-hidden="true"
        >☀</span>
        <span
          class="absolute right-1 top-1/2 -translate-y-1/2 text-[10px] text-subtle"
          aria-hidden="true"
        >☾</span>
        <span
          data-toggle-knob
          class="block h-5 w-5 rounded-full bg-ink shadow-sm transition-transform duration-200"
        ></span>
      </button>
    </div>
  </div>
</nav>

<script is:inline>
  (() => {
    const html = document.documentElement;
    const toggle = document.getElementById("theme-toggle");
    if (!toggle) return;

    const knob = toggle.querySelector("[data-toggle-knob]");

    const syncToggle = (theme) => {
      const isDark = theme === "dark";
      toggle.setAttribute("aria-pressed", String(isDark));
      if (knob) {
        knob.classList.toggle("translate-x-0", !isDark);
        knob.classList.toggle("translate-x-7", isDark);
      }
    };

    const current = html.getAttribute("data-theme") || "light";
    syncToggle(current);

    toggle.addEventListener("click", () => {
      const next = (html.getAttribute("data-theme") || "light") === "dark" ? "light" : "dark";
      html.setAttribute("data-theme", next);
      html.style.colorScheme = next;
      localStorage.setItem("theme", next);
      syncToggle(next);
    });
  })();
</script>
