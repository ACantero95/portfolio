---
interface Job {
  period: string;
  role: string;
  company: string;
  detail: string;
}

interface Props {
  jobs: Job[];
}

const { jobs } = Astro.props;
---

<section id="experience" class="px-6 py-20">
  <div class="max-w-6xl mx-auto">
    <h2 class="text-3xl sm:text-4xl font-black tracking-tight mb-10">
      Experiencia<span class="text-accent">.</span>
    </h2>

    <div class="relative space-y-6 pl-8 before:absolute before:left-3 before:top-2 before:bottom-2 before:w-px before:bg-gradient-to-b before:from-accent before:to-line">
      {jobs.map((job, i) => (
        <article class:list={["relative group animate-slide-left", i === 1 && "delay-200"]}>
          <!-- Dot -->
          <div class="absolute -left-5 top-2 w-3 h-3 rounded-full border-2 border-accent bg-paper group-hover:bg-accent transition-colors"></div>

          <div class="p-6 rounded-2xl border border-line/60 bg-surface hover:border-accent/30 transition-all hover:shadow-sm">
            <span class="text-xs font-bold text-accent uppercase tracking-widest">{job.period}</span>
            <h3 class="text-xl font-extrabold mt-1">{job.role}</h3>
            <p class="text-sm font-semibold text-subtle mt-0.5">{job.company}</p>
            <p class="mt-3 text-subtle leading-relaxed">{job.detail}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
